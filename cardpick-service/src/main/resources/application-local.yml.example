# ============================================================
# application-local.yml 설정 가이드
#
# 이 파일을 복사해서 application-local.yml 로 이름을 바꾼 뒤
# 아래 값들을 본인 환경에 맞게 수정하세요.
# ============================================================

spring:
  datasource:
    url: jdbc:postgresql://localhost:8091/cardpick
    username: ${DB_USERNAME:cardpick}
    password: ${DB_PASSWORD:cardpick}
    driver-class-name: org.postgresql.Driver

  data:
    redis:
      host: ${REDIS_HOST:localhost}
      port: ${REDIS_PORT:6380}
      password: ${REDIS_PASSWORD:}

jwt:
  secret: ${JWT_SECRET:여기에-로컬용-임시-시크릿-키-입력}
  expiration: ${JWT_EXPIRATION:86400000}

app:
  cors:
    # 허용할 프론트엔드 도메인 (콤마로 구분)
    allowed-origins: ${CORS_ALLOWED_ORIGINS:http://localhost:5173,http://localhost:3000}
    # 운영 예시: CORS_ALLOWED_ORIGINS=https://admin.example.com,https://example.com
  init:
    admin:
      login-id: ${ADMIN_LOGIN_ID:admin}
      password: ${ADMIN_PASSWORD:admin}
      name: ${ADMIN_NAME:관리자}

logging:
  level:
    org.hibernate.SQL: debug   # 로컬에서 SQL 로그 확인용 (운영에서는 warn 권장)
